NODE_ENV=development
LAPTOP_BRIDGE_PORT=8791
LAPTOP_BRIDGE_ID=jon-laptop-g2-bridge
LAPTOP_BRIDGE_DEVICE_ID=xreal-g2-local
LAPTOP_BRIDGE_ADAPTER_MODE=mock
LAPTOP_BRIDGE_RAW_BLE_DEBUG=false
LAPTOP_BRIDGE_RECONNECT_INITIAL_MS=1000
LAPTOP_BRIDGE_RECONNECT_MAX_MS=30000
LAPTOP_BRIDGE_RESUME_GAP_MS=15000
LAPTOP_BRIDGE_UPSTREAM_FLUSH_INTERVAL_MS=1000
LAPTOP_BRIDGE_UPSTREAM_MAX_BATCH_SIZE=25
LAPTOP_BRIDGE_UPSTREAM_MAX_QUEUE_SIZE=500
LAPTOP_BRIDGE_VPS_BASE_URL=https://api.example.com
LAPTOP_BRIDGE_VPS_TOKEN=replace-with-hardware-bridge-token
LAPTOP_BRIDGE_G2_NAME_PREFIX=XREAL
LAPTOP_BRIDGE_G2_SERVICE_UUID=
LAPTOP_BRIDGE_G2_RX_CHARACTERISTIC_UUID=
LAPTOP_BRIDGE_G2_TX_CHARACTERISTIC_UUID=
